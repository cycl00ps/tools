# Copy to .env in project root or export in your shell.
# OpenCode also reads .env from the project directory (see runbook).

# -----------------------------------------------------------------------------
# Default models (optional — can also set in opencode.jsonc)
# -----------------------------------------------------------------------------
# OPENCODE_MODEL=local-a/my-model-id
# OPENCODE_SMALL_MODEL=local-b/light-model-id

# -----------------------------------------------------------------------------
# Per-endpoint API keys (match names used in opencode.jsonc.template)
# Use one block per local OpenAI-compatible server.
# -----------------------------------------------------------------------------

# Provider ID: local-a (first direct endpoint)
LOCAL_A_API_KEY=replace-me

# Provider ID: local-b (second direct endpoint)
LOCAL_B_API_KEY=replace-me

# Provider ID: gateway (optional unified gateway — see template toggle)
GATEWAY_API_KEY=replace-me

# -----------------------------------------------------------------------------
# HTTPS / internal CA (optional)
# -----------------------------------------------------------------------------
# If your endpoints use TLS signed by an internal CA, trust it system-wide OR:
# NODE_EXTRA_CA_CERTS=/path/to/internal-ca-bundle.pem
# Many Go-based CLIs use the system store; install CA via update-ca-trust (see runbook).

# -----------------------------------------------------------------------------
# OpenCode paths (optional — setup script can set these)
# -----------------------------------------------------------------------------
# OPENCODE_CONFIG=/home/you/projects/opencode/config/opencode.jsonc
# OPENCODE_CONFIG_DIR=/home/you/projects/opencode/.opencode
